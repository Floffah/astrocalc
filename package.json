    "hono": "4.12.28",
    "neverthrow": "^8.2.0",
    "sweph": "2.10.3-7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/bun": "1.3.14",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "openapi-types": "12.1.3",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
